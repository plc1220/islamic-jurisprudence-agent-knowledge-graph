# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GEMINI MODEL CONFIGURATION (Defaults to config.json values if empty)
CRAWLER_MODEL="gemini-3.1-flash-lite"
CHAT_MODEL="gemini-3.5-flash"
EXTRACTOR_MODEL="gemini-3.5-flash"

# GOOGLE GEN AI SDK (VERTEX AI / ENTERPRISE CONFIGURATION)
# Authenticate with Application Default Credentials (ADC), not a Gemini API key.
GOOGLE_GENAI_USE_ENTERPRISE="true"
GOOGLE_GENAI_USE_VERTEXAI="true"

# Explicitly specify the Google Cloud project and locations.
# GCP_LOCATION is for regional resources; GEMINI_LOCATION/GOOGLE_CLOUD_LOCATION is for Gemini model calls.
GCP_PROJECT_ID=""
GCP_LOCATION="asia-southeast1"
GOOGLE_CLOUD_PROJECT=""
GEMINI_LOCATION="global"
GOOGLE_CLOUD_LOCATION="global"

# WEBSITE INGESTION PIPELINE
# crawl4ai is the primary crawler. If it is unavailable locally, the server falls back
# to Gemini HTML cleaning unless CRAWL4AI_FALLBACK_TO_GEMINI is set to "false".
INGESTION_CRAWLER="crawl4ai"
PYTHON_BIN="python3"
CRAWL4AI_BRIDGE_PATH=""
CRAWL_MAX_DEPTH="1"
CRAWL_MAX_PAGES_PER_SOURCE="3"
CRAWL_MIN_CHARS="450"
CRAWL4AI_TIMEOUT_MS="180000"
CRAWL4AI_FALLBACK_TO_GEMINI="true"

# GCP-NATIVE KNOWLEDGE PLATFORM
# BigQuery stores corpus/chunks/graph rows. Cloud Storage stores raw markdown
# snapshots. Knowledge Catalog stores governed context entries/aspects.
BQ_DATASET="mursyid_knowledge"
BQ_CORPUS_TABLE="corpus"
BQ_CHUNKS_TABLE="chunks"
BQ_GRAPH_TABLE="graph_edges"
BQ_FEEDBACK_TABLE="response_feedback"
BQ_EMBEDDING_MODEL="text-embedding-004"
GCS_RAW_BUCKET=""
KNOWLEDGE_CATALOG_ENTRY_GROUP="mursyid-knowledge"
KNOWLEDGE_CATALOG_ENTRY_TYPE="mursyid-knowledge-entry"
KNOWLEDGE_CATALOG_ASPECT_TYPE="mursyid-context"
MDCODE_EXPORT_DIR="catalog-export"

# PUBLIC-FACING COST CONTROLS
# Process-local TTL/LRU caches reduce repeated embedding, BigQuery retrieval, and
# exact answer generation cost while the Cloud Run instance is warm.
CACHE_ENABLED="true"
QUERY_NORMALIZATION_ENABLED="true"
EMBEDDING_CACHE_TTL_MS="86400000"
EMBEDDING_CACHE_MAX_ENTRIES="1000"
RETRIEVAL_CACHE_TTL_MS="900000"
RETRIEVAL_CACHE_MAX_ENTRIES="500"
CHAT_RESPONSE_CACHE_TTL_MS="300000"
CHAT_RESPONSE_CACHE_MAX_ENTRIES="250"
SHARED_CACHE_ENABLED="false"
REDIS_HOST=""
REDIS_PORT="6379"
REDIS_CONNECT_TIMEOUT_MS="500"
